# Production environment for compose.prod.yaml.
# Copy to .env.prod (git-ignored) and fill in real values:
#
#   docker compose -f compose.prod.yaml --env-file .env.prod up -d --build

# Symfony secret — generate with: openssl rand -hex 32
APP_SECRET=

# Database credentials (the app connects as user "salix")
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# Image to run; defaults to a local build (salix:prod).
# Point at a registry tag once images are built in CI.
#SALIX_IMAGE=ghcr.io/example/salix:v1.0.0

# Host port the app is published on (behind your TLS-terminating proxy)
#SALIX_HTTP_PORT=8000

# Trust X-Forwarded-* headers from the reverse proxy in front of the stack.
# "REMOTE_ADDR" trusts the direct upstream; or list proxy IPs/CIDRs.
#TRUSTED_PROXIES=REMOTE_ADDR

#TZ=Europe/Bratislava
