{% extends '@SalixCms/install/base.html.twig' %}

{% block title %}Installation complete{% endblock %}

{% block body %}
    <h1>Installation complete 🎉</h1>

    <div class="alert alert-success">
        Salix CMS is installed. The administrator account <strong>{{ adminEmail }}</strong> was created and the database is ready.
    </div>

    <div class="alert alert-warning">
        <strong>Finish securing your site:</strong>
        <ul>
            <li>The installer is now locked (a <code>var/installed.lock</code> file was written) and will refuse to run again.</li>
            <li>For defence in depth, delete <code>src/Controller/InstallController.php</code> from the deployment if you no longer need it.</li>
            <li>If you are running in the <code>prod</code> environment, clear the cache (<code>var/cache</code>) so the new database connection is picked up.</li>
        </ul>
    </div>

    <p><a href="{{ path('frontend_home') }}">Go to your site</a> · <a href="/admin/">Open the admin</a></p>
{% endblock %}
