{% extends '@SalixCms/install/base.html.twig' %}

{% block title %}Install Salix CMS{% endblock %}

{% block body %}
    <h1>Install Salix CMS</h1>
    <p class="lead">Configure the database and create the first administrator account.</p>

    {% if errors is not empty %}
        <div class="alert alert-danger">
            <strong>Installation could not be completed:</strong>
            <ul>
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_install') }}" autocomplete="off">
        <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">

        <fieldset>
            <legend>Administrator account</legend>

            <label for="adminName">Name</label>
            <input type="text" id="adminName" name="adminName" value="{{ values.adminName }}" required>

            <label for="adminEmail">Email</label>
            <input type="email" id="adminEmail" name="adminEmail" value="{{ values.adminEmail }}" required>

            <div class="row">
                <div>
                    <label for="adminPassword">Password</label>
                    <input type="password" id="adminPassword" name="adminPassword" minlength="8" required>
                    <p class="hint">At least 8 characters.</p>
                </div>
                <div>
                    <label for="adminPasswordConfirm">Confirm password</label>
                    <input type="password" id="adminPasswordConfirm" name="adminPasswordConfirm" minlength="8" required>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Database</legend>

            <label for="dbDriver">Database type</label>
            <select id="dbDriver" name="dbDriver">
                <option value="mysql"{{ values.dbDriver == 'mysql' ? ' selected' }}>MySQL</option>
                <option value="mariadb"{{ values.dbDriver == 'mariadb' ? ' selected' }}>MariaDB</option>
                <option value="postgresql"{{ values.dbDriver == 'postgresql' ? ' selected' }}>PostgreSQL</option>
            </select>

            <div class="row">
                <div>
                    <label for="dbHost">Host</label>
                    <input type="text" id="dbHost" name="dbHost" value="{{ values.dbHost }}" required>
                </div>
                <div>
                    <label for="dbPort">Port</label>
                    <input type="text" id="dbPort" name="dbPort" value="{{ values.dbPort }}" inputmode="numeric">
                </div>
            </div>

            <label for="dbName">Database name</label>
            <input type="text" id="dbName" name="dbName" value="{{ values.dbName }}" required>

            <div class="row">
                <div>
                    <label for="dbUser">Username</label>
                    <input type="text" id="dbUser" name="dbUser" value="{{ values.dbUser }}" required>
                </div>
                <div>
                    <label for="dbPassword">Password</label>
                    <input type="password" id="dbPassword" name="dbPassword">
                </div>
            </div>

            <label for="dbServerVersion">Server version <span class="hint">(optional)</span></label>
            <input type="text" id="dbServerVersion" name="dbServerVersion" value="{{ values.dbServerVersion }}" placeholder="Leave blank to use the default for the selected type">
        </fieldset>

        <button type="submit">Run installation</button>
    </form>
{% endblock %}
