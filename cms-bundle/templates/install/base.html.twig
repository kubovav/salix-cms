<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>{% block title %}Install{% endblock %} · Salix CMS</title>
    <style>
        :root { color-scheme: light dark; }
        * { box-sizing: border-box; }
        body {
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            margin: 0; padding: 2rem 1rem;
            background: #f4f5f7; color: #1f2330;
            display: flex; justify-content: center;
        }
        .card {
            background: #fff; width: 100%; max-width: 620px;
            border-radius: 12px; padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
        }
        h1 { margin: 0 0 .25rem; font-size: 1.5rem; }
        .lead { margin: 0 0 1.5rem; color: #6b7280; }
        fieldset { border: 1px solid #e5e7eb; border-radius: 8px; margin: 0 0 1.5rem; padding: 1rem 1.25rem 1.25rem; }
        legend { font-weight: 600; padding: 0 .4rem; }
        label { display: block; font-weight: 500; margin: .75rem 0 .25rem; font-size: .9rem; }
        input, select {
            width: 100%; padding: .55rem .65rem; font-size: 1rem;
            border: 1px solid #cbd1dc; border-radius: 6px; background: #fff; color: inherit;
        }
        input:focus, select:focus { outline: 2px solid #2563eb; outline-offset: 0; border-color: #2563eb; }
        .row { display: flex; gap: 1rem; }
        .row > * { flex: 1; }
        .hint { font-size: .8rem; color: #6b7280; margin-top: .25rem; }
        button {
            width: 100%; padding: .75rem 1rem; font-size: 1rem; font-weight: 600;
            color: #fff; background: #2563eb; border: 0; border-radius: 8px; cursor: pointer;
        }
        button:hover { background: #1d4ed8; }
        .alert { border-radius: 8px; padding: .85rem 1rem; margin: 0 0 1.5rem; font-size: .9rem; }
        .alert-danger { background: #fdecef; border: 1px solid #f5b5c0; color: #9b1c31; }
        .alert-success { background: #e7f6ec; border: 1px solid #a6dab9; color: #1b6b3a; }
        .alert-warning { background: #fff7e6; border: 1px solid #f2d38a; color: #8a5a00; }
        .alert ul { margin: .4rem 0 0; padding-left: 1.2rem; }
        code { background: #eef0f4; padding: .1rem .35rem; border-radius: 4px; font-size: .85em; }
    </style>
</head>
<body>
    <main class="card">
        {% block body %}{% endblock %}
    </main>
</body>
</html>
