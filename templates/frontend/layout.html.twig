<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{% endblock %}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="{{ asset('styles/frontend.css') }}">
        {% block stylesheets %}{% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="d-flex flex-column min-vh-100">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
            <div class="container">
                <a class="navbar-brand fw-semibold" href="{{ path('frontend_home') }}">
                    {% if brand_logo %}
                        <img src="{{ '/uploads/images/' ~ brand_logo }}" alt="{{ site_name|default('Salix CMS') }}" height="30">
                    {% else %}
                        {{ site_name|default('Salix CMS') }}
                    {% endif %}
                </a>
                <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain"
                    aria-controls="navbarMain"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        {% for item in menuItems %}
                            {% set itemUrl = item.url ?? (item.page ? path('frontend_page', { slug: item.page.slug }) : '#') %}
                            {% set enabledChildren = item.children|filter(c => c.enabled) %}
                            {% if enabledChildren|length > 0 %}
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                        {{ item.label }}
                                    </a>
                                    <ul class="dropdown-menu">
                                        {% for child in enabledChildren %}
                                            {% set childUrl = child.url ?? (child.page ? path('frontend_page', { slug: child.page.slug }) : '#') %}
                                            <li>
                                                <a class="dropdown-item" href="{{ childUrl }}">{{ child.label }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ itemUrl }}">{{ item.label }}</a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="flex-grow-1">
            {% block content %}{% endblock %}
        </main>

        <footer class="bg-dark text-white py-4 mt-5">
            <div class="container text-center">
                {% set enabledFooterItems = footerMenuItems|default([])|filter(item => item.enabled) %}
                {% if enabledFooterItems|length > 0 %}
                    <ul class="nav justify-content-center mb-3">
                        {% for item in enabledFooterItems %}
                            {% set itemUrl = item.url ?? (item.page ? path('frontend_page', { slug: item.page.slug }) : '#') %}
                            <li class="nav-item">
                                <a class="nav-link text-white-50" href="{{ itemUrl }}">{{ item.label }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
                <small class="text-secondary">&copy; {{ "now"|date("Y") }} {{ site_name|default('Salix CMS') }}</small>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
