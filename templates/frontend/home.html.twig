{% extends 'frontend/layout.html.twig' %}

{% block title %}{% endblock %}

{% block content %}
    {# CMS start page: shown whenever no page has been created yet, or a home page hasn't been chosen #}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 text-center">
                <div class="mb-4"><img width="200" src="{{ asset('images/salix-logo.png') }}"></div>
                <h1 class="display-5 fw-bold mb-3">Welcome to Salix CMS</h1>
                {% if pages is empty %}
                    <p class="lead text-muted mb-4">
                        Your site is live and ready. Get started by creating and publishing your first content page from the admin panel.
                    </p>
                {% else %}
                    <p class="lead text-muted mb-4">
                        Your site has published pages, but no home page has been set yet. Open <strong>Settings</strong> in the admin panel and choose which page to display here.
                    </p>
                {% endif %}
                <a href="/admin" class="btn btn-primary btn-lg px-5">
                    Go to Admin Panel
                </a>
            </div>
        </div>
    </div>
{% endblock %}
