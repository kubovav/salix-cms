{% extends 'admin/layout.html.twig' %}

{% block title %}Add Block — {{ page.title }}{% endblock %}

{% block page_title %}Add Block{% endblock %}

{% block breadcrumbs %}
  <li class="breadcrumb-item"><a href="{{ path('admin_articles_index') }}">Articles</a></li>
  <li class="breadcrumb-item"><a href="{{ path('admin_articles_edit', {id: page.id}) }}">{{ page.title }}</a></li>
  <li class="breadcrumb-item active" aria-current="page">Add Block</li>
{% endblock %}

{% block content %}
  <div class="row">
    <div class="col-lg-6">
      <div class="card card-primary card-outline">
        <div class="card-header">
          <h3 class="card-title">Choose Block Type</h3>
        </div>
        <div class="card-body">
          <div class="list-group">
            {% set typeIcons = {
              'rich_text': 'bi-card-text',
              'image': 'bi-image',
              'hero': 'bi-layout-text-window',
              'text_image': 'bi-layout-split',
              'cta': 'bi-cursor-fill'
            } %}
            {% set typeDescriptions = {
              'rich_text': 'Formatted text with headings, lists, bold/italic and more.',
              'image': 'A single image with alt text and optional caption.',
              'hero': 'Full-width banner with heading, subtext, and optional CTA button.',
              'text_image': 'Two-column layout with text alongside an image.',
              'cta': 'A callout section with a heading and a button link.'
            } %}
            {% for blockType in blockTypes %}
              <a href="{{ path('admin_block_new', {pageId: page.id, type: blockType.value}) }}"
                 class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3">
                <i class="bi {{ typeIcons[blockType.value]|default('bi-square') }} fs-4 text-primary mt-1"></i>
                <div>
                  <div class="fw-semibold">{{ blockType.label() }}</div>
                  <div class="text-muted small">{{ typeDescriptions[blockType.value]|default('') }}</div>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
        <div class="card-footer">
          <a href="{{ path('admin_articles_edit', {id: page.id}) }}" class="btn btn-secondary">Cancel</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
