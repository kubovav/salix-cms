<div class="mb-3">
  {{ form_label(form.alt, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.alt) }}
  {{ form_errors(form.alt) }}
</div>

<div class="mb-3">
  {{ form_label(form.caption, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.caption) }}
  {{ form_errors(form.caption) }}
</div>

<div class="mb-3">
  {{ form_label(form.file, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {% if isEdit and block is defined and block.data.filename is defined %}
    <div class="mb-2">
      <img src="{{ '/uploads/images/' ~ block.data.filename }}" alt="{{ block.data.alt|default('') }}" class="img-thumbnail" style="max-height:120px;">
      <div class="form-text text-muted">Upload a new file to replace the current image.</div>
    </div>
  {% endif %}
  {{ form_widget(form.file) }}
  {{ form_errors(form.file) }}
</div>
