<div class="mb-3">
  {{ form_label(form.heading, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.heading) }}
  {{ form_errors(form.heading) }}
</div>

<div class="mb-3">
  {{ form_label(form.subtext, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.subtext) }}
  {{ form_errors(form.subtext) }}
</div>

<hr class="my-3">
<p class="text-muted small mb-2">Optional: add a call-to-action button.</p>

<div class="row g-3 mb-3">
  <div class="col-md-5">
    {{ form_label(form.cta_text, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
    {{ form_widget(form.cta_text) }}
    {{ form_errors(form.cta_text) }}
  </div>
  <div class="col-md-7">
    {{ form_label(form.cta_url, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
    {{ form_widget(form.cta_url) }}
    {{ form_errors(form.cta_url) }}
  </div>
</div>

<hr class="my-3">
<p class="text-muted small mb-2">Optional: background image.</p>

<div class="mb-3">
  {{ form_label(form.image_alt, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.image_alt) }}
  {{ form_errors(form.image_alt) }}
</div>

<div class="mb-3">
  {{ form_label(form.file, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {% if isEdit and block is defined and block.data.filename is defined %}
    <div class="mb-2">
      <img src="{{ '/uploads/images/' ~ block.data.filename }}" alt="{{ block.data.image_alt|default('') }}" class="img-thumbnail" style="max-height:120px;">
      <div class="form-text text-muted">Upload a new file to replace the current background image.</div>
    </div>
  {% endif %}
  {{ form_widget(form.file) }}
  {{ form_errors(form.file) }}
</div>
