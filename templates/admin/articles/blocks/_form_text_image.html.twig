<div class="mb-3">
  {{ form_label(form.image_side, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.image_side) }}
  {{ form_errors(form.image_side) }}
</div>

<div class="mb-3">
  {{ form_label(form.html, 'Text content', { label_attr: { class: 'form-label fw-semibold' } }) }}
  <div class="quill-editor-wrapper">
    <div class="quill-editor" style="min-height:180px;"></div>
    {{ form_widget(form.html, { attr: { class: 'quill-target d-none' } }) }}
  </div>
  {{ form_errors(form.html) }}
</div>

<hr class="my-3">

<div class="mb-3">
  {{ form_label(form.image_alt, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {{ form_widget(form.image_alt) }}
  {{ form_errors(form.image_alt) }}
</div>

<div class="mb-3">
  {{ form_label(form.file, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
  {% if isEdit and block is defined and block.data.filename is defined %}
    <div class="mb-2">
      <img src="{{ '/uploads/images/' ~ block.data.filename }}" alt="{{ block.data.image_alt|default('') }}" class="img-thumbnail" style="max-height:120px;">
      <div class="form-text text-muted">Upload a new file to replace the current image.</div>
    </div>
  {% endif %}
  {{ form_widget(form.file) }}
  {{ form_errors(form.file) }}
</div>
