{% extends 'admin/layout.html.twig' %}

{% block title %}Edit — {{ page.title }}{% endblock %}

{% block page_title %}Edit Article{% endblock %}

{% block breadcrumbs %}
  <li class="breadcrumb-item"><a href="{{ path('admin_articles_index') }}">Articles</a></li>
  <li class="breadcrumb-item active" aria-current="page">{{ page.title }}</li>
{% endblock %}

{% block content %}
  {% for flash in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      {{ flash }}
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  {% endfor %}
  {% for flash in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      {{ flash }}
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  {% endfor %}

  <div class="row">
    <div class="col-lg-8">

      {# ── Article settings ── #}
      <div class="card card-primary card-outline mb-4">
        <div class="card-header">
          <h3 class="card-title">Article Settings</h3>
        </div>
        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
        <div class="card-body">

          <div class="mb-3">
            {{ form_label(form.title, 'Title', { label_attr: { class: 'form-label fw-semibold' } }) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
          </div>

          <div class="mb-3">
            {{ form_label(form.slug, 'Slug', { label_attr: { class: 'form-label fw-semibold' } }) }}
            <div class="input-group">
              <span class="input-group-text text-muted">/</span>
              {{ form_widget(form.slug) }}
            </div>
            <div class="form-text text-muted">Lowercase letters, numbers, and hyphens only. Used in the URL.</div>
            {{ form_errors(form.slug) }}
          </div>

          <div class="mb-3">
            <div class="form-check">
              {{ form_widget(form.published) }}
              {{ form_label(form.published, 'Published', { label_attr: { class: 'form-check-label' } }) }}
            </div>
          </div>

        </div>
        <div class="card-footer d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Save Settings
          </button>
          {% if page.published %}
            <a href="{{ path('frontend_page', {slug: page.slug}) }}" target="_blank" class="btn btn-outline-secondary">
              <i class="bi bi-box-arrow-up-right me-1"></i> View page
            </a>
          {% endif %}
        </div>
        {{ form_end(form) }}
      </div>

      {# ── Content blocks ── #}
      <div class="card card-outline mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Content Blocks</h3>
          <div class="card-tools">
            <a href="{{ path('admin_block_new', {pageId: page.id}) }}" class="btn btn-primary btn-sm">
              <i class="bi bi-plus-lg me-1"></i> Add Block
            </a>
          </div>
        </div>
        <div class="card-body p-0">
          {% if page.blocks is empty %}
            <p class="text-muted p-3 mb-0">No blocks yet. Use the <strong>Add Block</strong> button to add content.</p>
          {% else %}
            <table class="table table-hover mb-0 align-middle">
              <thead>
                <tr>
                  <th style="width:3rem">#</th>
                  <th>Type</th>
                  <th>Preview</th>
                  <th style="width:10rem"></th>
                </tr>
              </thead>
              <tbody>
                {% for block in page.blocks %}
                  <tr>
                    <td class="text-muted">{{ loop.index }}</td>
                    <td>
                      {% set typeLabels = {
                        'rich_text': 'Rich Text',
                        'image': 'Image',
                        'hero': 'Hero',
                        'text_image': 'Text + Image',
                        'cta': 'Call to Action'
                      } %}
                      {% set typeColors = {
                        'rich_text': 'secondary',
                        'image': 'info',
                        'hero': 'primary',
                        'text_image': 'warning',
                        'cta': 'success'
                      } %}
                      <span class="badge text-bg-{{ typeColors[block.type]|default('secondary') }}">
                        {{ typeLabels[block.type]|default(block.type) }}
                      </span>
                    </td>
                    <td class="text-muted small text-truncate" style="max-width:280px;">
                      {% if block.type == 'rich_text' %}
                        {{ block.data.html|striptags|slice(0, 80) }}
                      {% elseif block.type == 'hero' %}
                        {{ block.data.heading|default('') }}
                      {% elseif block.type == 'image' %}
                        <i class="bi bi-image me-1"></i>{{ block.data.alt|default('') }}
                      {% elseif block.type == 'text_image' %}
                        {{ block.data.html|striptags|slice(0, 60) }}
                      {% elseif block.type == 'cta' %}
                        {{ block.data.heading|default('') }} → {{ block.data.button_text|default('') }}
                      {% endif %}
                    </td>
                    <td class="text-end">
                      {# Move up #}
                      {% if not loop.first %}
                        <form method="post" action="{{ path('admin_block_move', {pageId: page.id, id: block.id}) }}" class="d-inline">
                          <input type="hidden" name="dir" value="up">
                          <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move up">
                            <i class="bi bi-arrow-up"></i>
                          </button>
                        </form>
                      {% endif %}
                      {# Move down #}
                      {% if not loop.last %}
                        <form method="post" action="{{ path('admin_block_move', {pageId: page.id, id: block.id}) }}" class="d-inline">
                          <input type="hidden" name="dir" value="down">
                          <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move down">
                            <i class="bi bi-arrow-down"></i>
                          </button>
                        </form>
                      {% endif %}
                      <a href="{{ path('admin_block_edit', {pageId: page.id, id: block.id}) }}" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="post" action="{{ path('admin_block_delete', {pageId: page.id, id: block.id}) }}" class="d-inline" onsubmit="return confirm('Delete this block?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_block_' ~ block.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
{% endblock %}
