{% extends 'admin/layout.html.twig' %}

{% block title %}Articles{% endblock %}

{% block page_title %}Articles{% endblock %}

{% block breadcrumbs %}
  <li class="breadcrumb-item active" aria-current="page">Articles</li>
{% endblock %}

{% block content %}
  {% for flash in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      {{ flash }}
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  {% endfor %}

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">All Articles</h3>
      <div class="card-tools">
        <a href="{{ path('admin_articles_new') }}" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i> New Article
        </a>
      </div>
    </div>
    <div class="card-body p-0">
      {% if articles is empty %}
        <p class="text-muted p-3 mb-0">No articles yet. <a href="{{ path('admin_articles_new') }}">Create the first one.</a></p>
      {% else %}
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Title</th>
              <th>Slug</th>
              <th>Status</th>
              <th>Updated</th>
            </tr>
          </thead>
          <tbody>
            {% for article in articles %}
              <tr>
                <td>{{ article.title }}</td>
                <td><code>{{ article.slug }}</code></td>
                <td>
                  {% if article.published %}
                    <span class="badge text-bg-success">Published</span>
                  {% else %}
                    <span class="badge text-bg-secondary">Draft</span>
                  {% endif %}
                </td>
                <td>{{ article.updatedAt ? article.updatedAt|date('Y-m-d H:i') : '—' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </div>
  </div>
{% endblock %}
