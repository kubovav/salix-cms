<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Admin{% endblock %} | Salix CMS</title>

  <!--begin::Bootstrap Icons-->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  <!--end::Bootstrap Icons-->

  <!--begin::AdminLTE-->
  <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.min.css') }}">
  <!--end::AdminLTE-->

  <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

{% block stylesheets %}{% endblock %}
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

<!--begin::App Wrapper-->
<div class="app-wrapper">

  <!--begin::Header-->
  <nav class="app-header navbar navbar-expand bg-body">
    <div class="container-fluid">
      <!--begin::Sidebar Toggle-->
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
            <i class="bi bi-list"></i>
          </a>
        </li>
      </ul>
      <!--end::Sidebar Toggle-->

      <!--begin::End Navbar-->
      <ul class="navbar-nav ms-auto">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle me-1"></i>
            {{ app.user.userIdentifier }}
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                <i class="bi bi-box-arrow-right me-2"></i>Logout
              </a>
            </li>
          </ul>
        </li>
      </ul>
      <!--end::End Navbar-->
    </div>
  </nav>
  <!--end::Header-->

  <!--begin::Sidebar-->
  <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    <!--begin::Sidebar Brand-->
    <div class="sidebar-brand">
      <a href="{{ path('admin_dashboard') }}" class="brand-link">
        <i class="bi bi-layers-fill brand-image opacity-75 fs-4 ms-2"></i>
        <span class="brand-text fw-light ms-2">Salix CMS</span>
      </a>
    </div>
    <!--end::Sidebar Brand-->

    <!--begin::Sidebar Wrapper-->
    <div class="sidebar-wrapper">
      <nav class="mt-2">
        <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation" data-accordion="false">

          <li class="nav-item">
            <a href="{{ path('admin_dashboard') }}" class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
              <i class="nav-icon bi bi-speedometer2"></i>
              <p>Dashboard</p>
            </a>
          </li>

          <li class="nav-item">
            <a href="{{ path('admin_articles_index') }}" class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_articles' %}active{% endif %}">
              <i class="nav-icon bi bi-file-earmark-text"></i>
              <p>Articles</p>
            </a>
          </li>

          <li class="nav-item">
            <a href="{{ path('admin_menu_index') }}" class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_menu' %}active{% endif %}">
              <i class="nav-icon bi bi-list-nested"></i>
              <p>Menu</p>
            </a>
          </li>

          <li class="nav-item">
            <a href="{{ path('admin_settings') }}" class="nav-link {% if app.request.attributes.get('_route') == 'admin_settings' %}active{% endif %}">
              <i class="nav-icon bi bi-gear"></i>
              <p>Settings</p>
            </a>
          </li>

          {% block sidebar_menu %}{% endblock %}

        </ul>
      </nav>
    </div>
    <!--end::Sidebar Wrapper-->
  </aside>
  <!--end::Sidebar-->

  <!--begin::App Main-->
  <main class="app-main">

    <!--begin::App Content Header-->
    <div class="app-content-header">
      <div class="container-fluid">
        <div class="row">
          <div class="col-sm-6">
            <h3 class="mb-0">{% block page_title %}{% endblock %}</h3>
          </div>
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
              <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Home</a></li>
              {% block breadcrumbs %}{% endblock %}
            </ol>
          </div>
        </div>
      </div>
    </div>
    <!--end::App Content Header-->

    <!--begin::App Content-->
    <div class="app-content">
      <div class="container-fluid">
        {% block content %}{% endblock %}
      </div>
    </div>
    <!--end::App Content-->

  </main>
  <!--end::App Main-->

</div>
<!--end::App Wrapper-->

<!--begin::Sidebar Overlay-->
<div class="sidebar-overlay"></div>
<!--end::Sidebar Overlay-->

<!--begin::Bootstrap-->
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>
<!--end::Bootstrap-->

<!--begin::AdminLTE-->
<script src="{{ asset('adminlte/js/adminlte.min.js') }}"></script>
<!--end::AdminLTE-->

{% block javascripts %}{% endblock %}
</body>
</html>
